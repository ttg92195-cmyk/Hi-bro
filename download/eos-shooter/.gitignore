# ============================================================================
# EOS Shooter - .gitignore
# ============================================================================

# Build directories
build/
out/
cmake-build-*/

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Compiled objects (but NOT EOS SDK libs)
*.o
*.obj
*.so
*.dylib
*.dll
*.exe

# Ignore .a and .lib everywhere EXCEPT EOS SDK
*.a
*.lib
!third_party/eos-sdk/**/*.a
!third_party/eos-sdk/**/*.lib

# Android
android/.gradle/
android/app/build/
android/build/
*.apk
*.aab
local.properties

# Raylib (submodule or cloned)
third_party/raylib/

# Assets that are too large for git
assets/models/*.glb
assets/models/*.gltf
assets/textures/*.png.bak

# Python
__pycache__/
*.pyc

# Logs
*.log

# Package files
*.zip
*.tar.gz

# CMake generated
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
compile_commands.json
Makefile
