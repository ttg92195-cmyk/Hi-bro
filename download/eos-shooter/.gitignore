# ============================================================================
# EOS Shooter - .gitignore
# ============================================================================

# Build directories
build/
out/
cmake-build-*/

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Compiled objects (NOT EOS SDK libs)
*.o
*.obj

# Shared libraries - but allow EOS SDK
*.so
!third_party/eos-sdk/**/*.so

# Executables - but allow EOS SDK Tools
*.exe
!third_party/eos-sdk/**/*.exe

# Static/Dynamic libs - but allow EOS SDK
*.a
*.lib
*.dll
*.dylib
*.exe
!third_party/eos-sdk/**/*.a
!third_party/eos-sdk/**/*.lib

# Android AAR - allow EOS SDK
*.aar
!third_party/eos-sdk/**/*.aar

# Android build
android/.gradle/
android/app/build/
android/build/
*.apk
*.aab
local.properties

# Raylib (submodule or cloned)
third_party/raylib/

# Temp extraction files
eos-temp/

# Assets that are too large for git
assets/models/*.glb
assets/models/*.gltf
assets/textures/*.png.bak

# Python
__pycache__/
*.pyc

# Logs
*.log

# Package files (NOT in third_party)
*.zip
*.tar.gz
!third_party/eos-sdk/**/*.zip
!third_party/eos-sdk/**/*.tar.gz

# CMake generated
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
compile_commands.json
Makefile
